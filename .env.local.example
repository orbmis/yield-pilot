# Copy this file to .env.local for local Next.js development.
# In Vercel/Railway, configure these as project environment variables instead.

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/yieldpilot?schema=public"

# Fixture mode lets the app run without live provider credentials.
USE_FIXTURES="true"

# Privy authentication.
NEXT_PUBLIC_PRIVY_APP_ID=""
PRIVY_APP_ID=""
PRIVY_APP_SECRET=""
PRIVY_WALLET_AUTHORIZATION_PRIVATE_KEY=""
PRIVY_DELEGATED_NETWORK_ID="base-mainnet"
NEXT_PUBLIC_PRIVY_SIGNER_ID=""
NEXT_PUBLIC_PRIVY_POLICY_IDS=""

# OpenAI Responses API.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.2"

# Zapper GraphQL API.
ZAPPER_API_KEY=""
ZAPPER_NETWORKS=""

# Tenderly Simulation API.
TENDERLY_ACCESS_KEY=""
TENDERLY_ACCOUNT_SLUG=""
TENDERLY_PROJECT_SLUG=""

# Coinbase AgentKit uses the user's delegated Privy embedded wallet.
